# AAP Migration Planner - Configuration Example
# Copy this file to .env and customize for your environment

# ============================================================================
# AAP Connection
# ============================================================================
AAP_URL=https://your-aap-controller.example.com
AAP_TOKEN=your_api_token_here
AAP_VERIFY_SSL=false  # Set to true in production with valid certificates

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FORMAT=json  # json, text

# ============================================================================
# Analysis Options (Optional)
# ============================================================================
# ANALYSIS_TIMEOUT=300
# ANALYSIS_MAX_CONCURRENT=5

# ============================================================================
# Report Options (Optional)
# ============================================================================
# REPORT_OUTPUT_DIR=reports/
# REPORT_DEFAULT_FORMAT=html  # html, text, json
