# AAP Connection Configuration
# SECURITY: Only HTTPS URLs are accepted. HTTP is blocked to protect API tokens.
AAP_URL=https://aap-controller.example.com
AAP_TOKEN=your_api_token_here
AAP_VERIFY_SSL=false

# Logging
LOG_LEVEL=INFO

# Web UI Configuration
STREAMLIT_SERVER_PORT=8501

# Sizing Guide URL (internal to Docker network)
SIZING_GUIDE_URL=http://sizing-guide:5002

# Optional: Database (for future features)
# DATABASE_URL=postgresql://user:password@db:5432/aap_toolkit
